#include <stdio.h>
#include <string.h>
#include <stdlib.h>

const char fileName[40] = "DSACH.c";

typedef struct st {
    char ho_ten[40];
    int tuoi;
    double diem_tb;
    struct st *next;
} st;

typedef struct list {
    st *first;
    int tongso;
} list;

void initList(list *l) {
    l->first = NULL;
    l->tongso = 0;
}

st *newSt(char *nm, int t, double dtb) {
    st *cre = (st *) malloc(sizeof(st));
    if (cre != NULL) {
        strcpy(cre->ho_ten, nm);
        cre->tuoi = t;
        cre->diem_tb = dtb;
        cre->next = NULL;
    }
    return cre;
}

void append(list *l, st *app) {
    app->next = NULL;
    if (l == NULL) return;
    if (l->first == NULL) {
        l->first =app;
        l->tongso++;
        return;
    }

    st *curr = l->first;
    while (curr->next != NULL) {
        curr = curr->next;
    }
    curr->next = app;
    l->tongso++;
}

void showlist(list *l) {
    if (l == NULL || l->tongso == 0) return;

    printf("%-5s%-40s%-5s%-5s\n", "STT", "HO TEN", "TUOI", "DTB");

    st *curr = l->first;
    int i = 1;
    while (curr != NULL) {
        printf("%-5d%-40s%-5d%-5.2lf\n", i, curr->ho_ten, curr->tuoi, curr->diem_tb);
        i += 1;
        curr = curr->next;
    }
}

void WRITE(list *l) {
    FILE *fw = fopen(fileName, "wb");

    if (fw == NULL || l == NULL) return;

    // fwrite(&l->tongso, sizeof(int), 1, fw);

    st *curr = l->first;
    while (curr != NULL) {
        fwrite(curr->ho_ten, sizeof(curr->ho_ten), 1, fw);
        fwrite(&curr->tuoi, sizeof(int), 1, fw);
        fwrite(&curr->diem_tb, sizeof(double), 1, fw);
        curr = curr->next;
    }
}

