void WA(list *l) {
    FILE *fwa = fopen(fileName, "ab");

    if (fwa == NULL || l == NULL) return;
    char nm[40];
    int t;
    double dtb;
    getchar();
    printf("===Thong tin sv===\n");
    printf("Ho ten: ");
    fgets(nm, sizeof(nm), stdin);
    nm[strcspn(nm, "\n")] = 0;
    printf("Tuoi: ");
    scanf("%d", &t);
    printf("Diem tb: ");
    scanf("%lf", &dtb);
    append(l, newSt(nm, t, dtb));
    l->tongso++;
    fwrite(&nm, sizeof(nm), 1, fwa);
    fwrite(&t, sizeof(t), 1, fwa);
    fwrite(&dtb, sizeof(dtb), 1, fwa);
}

int main() {
    list *lt = (list *) malloc(sizeof(list));
    initList(lt);
    int feature = -1;

    do {
        printf("\t1. Write\n\t2. Show\n\t3. Append\n\t4. Edit\n\t0. Exit\n>>> ");
        scanf("%d", &feature);

        if (feature == 1) {
            int n;
            printf("SL sv: ");
            scanf("%d", &n);
            getchar();

            for (int i = 1; i < n + 1; i++) {
                char nm[40];
                int t;
                double dtb;
                printf("===Thong tin sv %d===\n", i);
                printf("Ho ten: ");
                fgets(nm, sizeof(nm), stdin);
                nm[strcspn(nm, "\n")] = 0;
                printf("Tuoi: ");
                scanf("%d", &t);
                printf("Diem tb: ");
                scanf("%lf", &dtb);
                getchar();
                append(lt, newSt(nm, t, dtb));
            }
        }

        if (feature == 2) {
            showlist(lt);
        }

        if (feature == 3) {
            WA(lt);
        }

        if (feature == 4) {
            //
        }

        if (feature == 0) break;
    } while (feature != 0);

}
